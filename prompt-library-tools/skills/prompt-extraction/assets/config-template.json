{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Configuration for prompt-library-tools plugin",
  "vault_path": "~/prompts",
  "import_path": "~/Downloads/newsletters",
  "min_confidence": 0.15,
  "templates": {
    "prompt_template": "assets/templates/prompt-template.md",
    "daily_note_template": "assets/templates/daily-note-with-prompts.md"
  },
  "extraction": {
    "auto_tag": true,
    "default_tags": ["prompt", "imported"],
    "preserve_markdown": true
  }
}
