# Git sparse checkout of charly-server developer-tools
# This is used for development and bundling scripts
charly-server-dev-tools/

# Packaged skills (build artifacts)
*.zip

# Backup files
*.backup
*~

# Claude Code local configuration (symlink and directory)
.claude
.claude/

# JIRA configuration (contains credentials)
.jira-analyzer.json
__pycache__/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
issues.jsonl

# Worktree IPC files (transient, must never be committed)
.worktree-handoff.json
.worktree-turns.jsonl
