# Git sparse checkout of charly-server developer-tools
# This is used for development and bundling scripts
charly-server-dev-tools/

# Packaged skills (build artifacts)
*.zip

# Backup files
*.backup
*~

# Claude Code local configuration — ignore contents selectively.
# (Full-dir exclusion would block subpath negation, so we exclude immediate
# children only and re-include the standards subtree.)
.claude/*
# Exceptions: marketplace-meta content is version-controlled.
# - standards/  — project-local standards loaded by inject-standards
# - commands/   — project-local slash commands (marketplace install helpers)
# - agents/     — placeholder for future project-local agents
# - settings.json — shared hook configuration (bd prime on SessionStart)
!.claude/standards/
!.claude/commands/
!.claude/agents/
!.claude/settings.json

# JIRA configuration (contains credentials)
.jira-analyzer.json
__pycache__/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
issues.jsonl

# Worktree IPC files (transient, must never be committed)
.worktree-handoff.json
.worktree-turns.jsonl
.wave-orchestrator.lock
.session-close.lock

# Embedded Dolt runtime state
embeddeddolt/

# In-repo Codex mirrors (dev-repo principle: this repo is dev-only, not a runtime source).
# Sync targets are user-scoped: ~/.codex/skills, ~/.codex/agents.
# See docs/architecture/dev-repo-principle.md — these dirs must never be re-committed.
.agents/
.codex/
