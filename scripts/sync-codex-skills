#!/usr/bin/env python3
"""Sync all Codex-exportable skills into the user-scoped skill directory.

This repository is a development repository — it is NOT a runtime source of truth.
The only sync target is the user-scoped directory (~/.codex/skills or ~/.agents/skills).
No in-repo mirror is created or maintained.

See docs/architecture/dev-repo-principle.md for the governing principle.
"""

from __future__ import annotations

import argparse
import hashlib
import shutil
import sys
import tempfile
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
REPO_ROOT = SCRIPT_DIR.parent
sys.path.insert(0, str(SCRIPT_DIR))

from codex_skills import build_skill_export, discover_skills, exportable_skills  # noqa: E402


def resolve_user_target() -> Path | None:
    candidates = [Path.home() / ".codex" / "skills", Path.home() / ".agents" / "skills"]
    for candidate in candidates:
        if candidate.is_dir():
            return candidate
    return None


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Sync all Codex-exportable skills into the user-scoped Codex skills directory "
            "(~/.codex/skills or ~/.agents/skills). "
            "No in-repo mirror is created — this repo is dev-only. "
            "See docs/architecture/dev-repo-principle.md."
        )
    )
    parser.add_argument("--check", action="store_true", help="Exit 1 if any target is out of sync.")
    parser.add_argument("--dry-run", action="store_true", help="Print what would change without writing files.")
    parser.add_argument(
        "--skills",
        help="Comma-separated subset of skill names to sync or check. Default: all exportable skills.",
    )
    return parser.parse_args()


def parse_skill_filter(raw_value: str | None) -> list[str] | None:
    if raw_value is None:
        return None
    names = [item.strip() for item in raw_value.split(",")]
    if any(not item for item in names):
        raise ValueError("empty skill name in --skills list")
    return names


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(65536), b""):
            digest.update(chunk)
    return digest.hexdigest()


def tree_signature(root: Path) -> dict[str, str] | None:
    if not root.is_dir():
        return None
    signature: dict[str, str] = {}
    for path in sorted(root.rglob("*")):
        if path.is_dir():
            continue
        rel = path.relative_to(root)
        if "__pycache__" in rel.parts:
            continue
        signature[str(rel)] = sha256_file(path)
    return signature


def sync_tree(source: Path, destination: Path) -> None:
    if destination.exists():
        shutil.rmtree(destination)
    shutil.copytree(source, destination)


def main() -> None:
    args = parse_args()
    try:
        skill_filter = parse_skill_filter(args.skills)
    except ValueError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        raise SystemExit(2) from exc

    records = exportable_skills(discover_skills())
    records_by_name = {record.name: record for record in records}

    if skill_filter is not None:
        missing = [name for name in skill_filter if name not in records_by_name]
        if missing:
            print(f"ERROR: unknown or non-exportable skills: {', '.join(missing)}", file=sys.stderr)
            raise SystemExit(2)
        selected = [records_by_name[name] for name in skill_filter]
    else:
        selected = records

    user_target = resolve_user_target()
    if user_target is None:
        print("WARNING: no user-scoped skills directory found.", file=sys.stderr)
        print("         Checked: ~/.codex/skills, ~/.agents/skills", file=sys.stderr)
        print("         Create one of these directories first, then re-run.", file=sys.stderr)
        raise SystemExit(1)

    with tempfile.TemporaryDirectory(prefix="codex-skills-sync-") as temp_dir:
        stage_root = Path(temp_dir)
        for record in selected:
            build_skill_export(record, stage_root / record.name)

        out_of_sync: list[str] = []

        if args.check:
            for record in selected:
                staged = stage_root / record.name
                user_destination = user_target / record.name
                if tree_signature(staged) == tree_signature(user_destination):
                    print(f"  [ok]   user-scoped ({user_target}): {record.name}")
                else:
                    print(
                        f"  [DIFF] user-scoped ({user_target}): {record.name}  "
                        "(run sync-codex-skills to update)"
                    )
                    out_of_sync.append(f"user:{record.name}")

            if skill_filter is None:
                expected_names = {record.name for record in selected}
                actual_names = {path.name for path in user_target.iterdir()} if user_target.is_dir() else set()
                stale_names = sorted(name for name in actual_names - expected_names if not name.startswith("."))
                for stale in stale_names:
                    print(f"  [DIFF] user-scoped stale skill: {stale}  (run sync-codex-skills to prune)")
                    out_of_sync.append(f"user-stale:{stale}")

            print("")
            if out_of_sync:
                print(f"Out of sync ({len(out_of_sync)} target(s)):")
                for item in out_of_sync:
                    print(f"  - {item}")
                raise SystemExit(1)

            print("All targets in sync.")
            return

        if args.dry_run:
            for record in selected:
                staged = stage_root / record.name
                print(f"  [dry]  would sync {staged} -> {user_target / record.name}")

            if skill_filter is None and user_target.is_dir():
                expected_names = {record.name for record in selected}
                actual_names = {path.name for path in user_target.iterdir()}
                stale_names = sorted(name for name in actual_names - expected_names if not name.startswith("."))
                for stale in stale_names:
                    print(f"  [dry]  would remove stale user-scoped skill {user_target / stale}")

            print("")
            print("Dry-run complete. No files were written.")
            return

        user_target.mkdir(parents=True, exist_ok=True)
        for record in selected:
            sync_tree(stage_root / record.name, user_target / record.name)
            print(f"  [sync] user-scoped: {record.name} -> {user_target / record.name}")

        if skill_filter is None and user_target.is_dir():
            expected_names = {record.name for record in selected}
            actual_paths = [path for path in user_target.iterdir() if path.is_dir() and not path.name.startswith(".")]
            for stale_path in sorted(actual_paths, key=lambda path: path.name):
                if stale_path.name not in expected_names:
                    shutil.rmtree(stale_path)
                    print(f"  [sync] user-scoped: pruned stale {stale_path}")

        print("")
        print("Sync complete.")
        print(f"User-scoped target: {user_target}")


if __name__ == "__main__":
    main()
