#!/usr/bin/env python3
"""Sync tracked Codex agents into repo and optional user-scoped targets."""

from __future__ import annotations

import argparse
import hashlib
import shutil
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
REPO_ROOT = SCRIPT_DIR.parent
sys.path.insert(0, str(SCRIPT_DIR))

from codex_agents import REPO_TARGET, discover_agents  # noqa: E402


def resolve_user_target() -> Path:
    return Path.home() / ".codex" / "agents"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Sync all tracked Codex agents from dev-tools/codex-agents/ into .codex/agents/ "
            "and optionally into ~/.codex/agents/."
        )
    )
    parser.add_argument("--user", action="store_true", help="Also sync to ~/.codex/agents/.")
    parser.add_argument("--check", action="store_true", help="Exit 1 if any target is out of sync.")
    parser.add_argument("--dry-run", action="store_true", help="Print what would change without writing files.")
    parser.add_argument(
        "--agents",
        help="Comma-separated subset of agent names to sync or check. Default: all tracked agents.",
    )
    return parser.parse_args()


def parse_agent_filter(raw_value: str | None) -> list[str] | None:
    if raw_value is None:
        return None
    names = [item.strip() for item in raw_value.split(",")]
    if any(not item for item in names):
        raise ValueError("empty agent name in --agents list")
    return names


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(65536), b""):
            digest.update(chunk)
    return digest.hexdigest()


def file_signature(path: Path) -> str | None:
    if not path.is_file():
        return None
    return sha256_file(path)


def sync_file(source: Path, destination: Path) -> None:
    destination.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(source, destination)


def main() -> None:
    args = parse_args()
    try:
        agent_filter = parse_agent_filter(args.agents)
    except ValueError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        raise SystemExit(2) from exc

    records = discover_agents()
    records_by_name = {record.name: record for record in records}

    if agent_filter is not None:
        missing = [name for name in agent_filter if name not in records_by_name]
        if missing:
            print(f"ERROR: unknown agents: {', '.join(missing)}", file=sys.stderr)
            raise SystemExit(2)
        selected = [records_by_name[name] for name in agent_filter]
    else:
        selected = records

    user_target = resolve_user_target() if args.user else None
    out_of_sync: list[str] = []

    if args.check:
        for record in selected:
            source = record.source_path
            repo_destination = REPO_TARGET / source.name
            if file_signature(source) == file_signature(repo_destination):
                print(f"  [ok]   repo-scoped: {record.name}")
            else:
                print(f"  [DIFF] repo-scoped: {record.name}  (run sync-codex-agents to update)")
                out_of_sync.append(f"repo:{record.name}")

            if user_target is not None:
                user_destination = user_target / source.name
                if file_signature(source) == file_signature(user_destination):
                    print(f"  [ok]   user-scoped ({user_target}): {record.name}")
                else:
                    print(
                        f"  [DIFF] user-scoped ({user_target}): {record.name}  "
                        "(run sync-codex-agents --user to update)"
                    )
                    out_of_sync.append(f"user:{record.name}")

        if agent_filter is None:
            expected_names = {record.name for record in selected}
            actual_names = {path.stem for path in REPO_TARGET.glob("*.toml")} if REPO_TARGET.is_dir() else set()
            stale_names = sorted(name for name in actual_names - expected_names)
            for stale in stale_names:
                print(f"  [DIFF] repo-scoped stale agent: {stale}  (run sync-codex-agents to prune)")
                out_of_sync.append(f"repo-stale:{stale}")

        print("")
        if out_of_sync:
            print(f"Out of sync ({len(out_of_sync)} target(s)):")
            for item in out_of_sync:
                print(f"  - {item}")
            raise SystemExit(1)

        print("All targets in sync.")
        return

    if args.dry_run:
        for record in selected:
            source = record.source_path
            print(f"  [dry]  would sync {source} -> {REPO_TARGET / source.name}")
            if user_target is not None:
                print(f"  [dry]  would sync {source} -> {user_target / source.name}")

        if agent_filter is None and REPO_TARGET.is_dir():
            expected_names = {record.name for record in selected}
            actual_paths = [path for path in REPO_TARGET.glob("*.toml") if path.is_file()]
            for stale_path in sorted(actual_paths, key=lambda path: path.name):
                if stale_path.stem not in expected_names:
                    print(f"  [dry]  would remove stale repo-scoped agent {stale_path}")

        print("")
        print("Dry-run complete. No files were written.")
        return

    REPO_TARGET.mkdir(parents=True, exist_ok=True)
    for record in selected:
        source = record.source_path
        repo_destination = REPO_TARGET / source.name
        sync_file(source, repo_destination)
        print(f"  [sync] repo-scoped: {record.name} -> {repo_destination}")

    if agent_filter is None and REPO_TARGET.is_dir():
        expected_names = {record.name for record in selected}
        actual_paths = [path for path in REPO_TARGET.glob("*.toml") if path.is_file()]
        for stale_path in sorted(actual_paths, key=lambda path: path.name):
            if stale_path.stem not in expected_names:
                stale_path.unlink()
                print(f"  [sync] repo-scoped: pruned stale {stale_path}")

    if user_target is not None:
        user_target.mkdir(parents=True, exist_ok=True)
        for record in selected:
            source = record.source_path
            user_destination = user_target / source.name
            sync_file(source, user_destination)
            print(f"  [sync] user-scoped: {record.name} -> {user_destination}")

    print("")
    print("Sync complete.")
    if user_target is not None:
        print(f"User-scoped target: {user_target}")


if __name__ == "__main__":
    main()
